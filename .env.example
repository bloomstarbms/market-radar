# Telegram bot token from @BotFather. Leave empty to run console-only.
TELEGRAM_BOT_TOKEN=
# Poll interval in seconds (applies to both DEX and CEX)
POLL_INTERVAL=60
# Cooldown per token/pair between repeat alerts (minutes)
ALERT_COOLDOWN_MIN=30
# CEX exchanges to monitor (comma-separated). Remove any you don't want.
CEX_EXCHANGES=binance,mexc,bybit

# --- On-chain whale alerts (optional, free keys) ---
# EVM chains (ETH/BSC/Base/...): free key from https://etherscan.io/apis
ETHERSCAN_API_KEY=
# Solana: free key from https://helius.dev
HELIUS_API_KEY=
# Whale thresholds: alert when a single transfer exceeds
# min(WHALE_USD, WHALE_LIQ_PCT% of pair liquidity)
WHALE_USD=1000000
WHALE_LIQ_PCT=20
